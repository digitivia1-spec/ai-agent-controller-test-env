    {
      "parameters": {
        "jsCode": "\nconst payload = $json ?? {};\nconst body = (payload.body && typeof payload.body === 'object') ? payload.body : payload;\n\nconst orgId        = String(body.org_id        || '').trim();\nconst submissionId = String(body.submission_id || '').trim();\nconst rawName      = String(body.template_name || '').trim();\nconst templateName = rawName.toLowerCase().replace(/[^a-z0-9_]/g, '_').replace(/^_+|_+$/g, '');\nconst templateLang = String(body.template_language || '').trim();\nconst category     = String(body.category     || '').trim().toUpperCase();\nconst bodyText     = String(body.body_text || body.body || '').trim();\nconst headerType   = String(body.header_type  || 'none').trim().toLowerCase();\nconst headerText   = String(body.header_text  || '').trim();\nconst footerText   = String(body.footer_text  || '').trim();\nconst buttons      = Array.isArray(body.buttons) ? body.buttons : null;\nconst varSamples   = (body.variable_samples && typeof body.variable_samples === 'object') ? body.variable_samples : null;\n\nconst errors = [];\nif (!orgId)        errors.push('missing_org_id');\nif (!templateName) errors.push('missing_template_name');\nif (!templateLang) errors.push('missing_template_language');\nif (!['MARKETING','UTILITY','AUTHENTICATION'].includes(category)) errors.push('invalid_category: must be MARKETING, UTILITY, or AUTHENTICATION');\nif (!bodyText)     errors.push('missing_body_text');\nif (!submissionId) errors.push('missing_submission_id');\n\nreturn [{ json: {\n  valid: errors.length === 0,\n  validation_error: errors.length ? errors.join(' | ') : null,\n  org_id: orgId,\n  submission_id: submissionId,\n  template_name: templateName,\n  template_language: templateLang,\n  category: category,\n  body_text: bodyText,\n  header_type: headerType,\n  header_text: headerText,\n  footer_text: footerText,\n  buttons: buttons,\n  variable_samples: varSamples,\n  now_iso: new Date().toISOString()\n}}];\n"
      },
