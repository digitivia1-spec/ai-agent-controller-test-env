    {
      "parameters": {
        "jsCode": "\n// Load followup_settings to see if this template is the assigned follow-up template\n// and whether notifications are enabled\nconst ctx          = $('Process Status Update').item.json;\nconst settingsRows = $input.all().map(i => i.json).filter(r => r && (r.id || r.org_id));\nconst settings     = settingsRows[0] || null;\n\nconst assignedName = settings?.whatsapp_template_name     || null;\nconst assignedLang = settings?.whatsapp_template_language || null;\nconst isAssigned   = assignedName && assignedLang &&\n  String(assignedName).toLowerCase() === String(ctx.template_name || '').toLowerCase() &&\n  String(assignedLang).toLowerCase() === String(ctx.template_language || '').toLowerCase();\n\nconst notifApproved = settings?.notification_on_template_approved !== false;\nconst notifRejected = settings?.notification_on_template_rejected !== false;\n\nconst shouldNotify = ctx.should_notify &&\n  ((ctx.is_approved && notifApproved) || (!ctx.is_approved && notifRejected));\n\nreturn [{ json: {\n  ...ctx,\n  is_assigned_followup_template: isAssigned,\n  should_update_followup_settings: isAssigned,\n  should_create_notification: shouldNotify\n}}];\n"
      },
