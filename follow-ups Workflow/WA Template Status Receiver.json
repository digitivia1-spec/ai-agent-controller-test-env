    {
      "parameters": {
        "jsCode": "\nconst input = $('Normalize Input').item.json;\nconst accountRows = $input.all().map(i => i.json).filter(r => r && r.id);\nconst account = accountRows[0] || null;\n\nif (!account) {\n  return [{ json: { ...input, submission_valid: false,\n    submission_error: 'no_active_whatsapp_channel_account_found_for_this_org' }}];\n}\n\nconst wabaId      = account.waba_id || account.external_account_id || null;\nconst accessToken = account.access_token || null;\n\nif (!wabaId) {\n  return [{ json: { ...input, submission_valid: false,\n    submission_error: 'waba_id_missing_in_org_channel_accounts \u00e2\u20ac\u201d add waba_id column or ensure external_account_id is the WABA ID' }}];\n}\nif (!accessToken) {\n  return [{ json: { ...input, submission_valid: false,\n    submission_error: 'access_token_missing_in_org_channel_accounts \u00e2\u20ac\u201d system user token required' }}];\n}\n\n// Build Meta components array\nconst components = [];\n\n// HEADER (optional)\nif (input.header_type && input.header_type !== 'none') {\n  const fmt = input.header_type.toUpperCase();\n  const hdr = { type: 'HEADER', format: fmt };\n  if (fmt === 'TEXT' && input.header_text) {\n    hdr.text = input.header_text;\n    if (/\\{\\{1\\}\\}/.test(input.header_text)) {\n      hdr.example = { header_text: ['Sample value'] };\n    }\n  }\n  components.push(hdr);\n}\n\n// BODY (required)\nconst bodyComp = { type: 'BODY', text: input.body_text };\nconst samples = input.variable_samples || {};\nconst varNums = [...new Set(\n  (input.body_text.match(/\\{\\{(\\d+)\\}\\}/g) || []).map(m => parseInt(m.replace(/\\D/g,''), 10))\n)].sort((a,b) => a-b);\n\nif (varNums.length > 0) {\n  const exampleRow = varNums.map(n => String(samples[n] || samples[String(n)] || `sample_${n}`));\n  bodyComp.example = { body_text: [exampleRow] };\n}\ncomponents.push(bodyComp);\n\n// FOOTER (optional)\nif (input.footer_text) {\n  components.push({ type: 'FOOTER', text: input.footer_text });\n}\n\n// BUTTONS (optional)\nif (Array.isArray(input.buttons) && input.buttons.length > 0) {\n  const metaBtns = input.buttons\n    .filter(b => b && b.text)\n    .slice(0, 3)\n    .map(b => {\n      const btn = { type: b.type || 'QUICK_REPLY', text: String(b.text).slice(0, 25) };\n      if (btn.type === 'URL'          && b.value) btn.url          = b.value;\n      if (btn.type === 'PHONE_NUMBER' && b.value) btn.phone_number = b.value;\n      return btn;\n    });\n  if (metaBtns.length) components.push({ type: 'BUTTONS', buttons: metaBtns });\n}\n\nconst metaBody = {\n  name: input.template_name,\n  language: input.template_language,\n  category: input.category,\n  components: components\n};\n\nreturn [{ json: {\n  ...input,\n  submission_valid: true,\n  waba_id: wabaId,\n  access_token: accessToken,\n  org_channel_account_id: account.id,\n  components: components,\n  meta_request_body: metaBody,\n  meta_api_url: 'https://graph.facebook.com/v23.0/' + wabaId + '/message_templates'\n}}];\n"
      },
