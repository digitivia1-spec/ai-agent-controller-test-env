    {
      "parameters": {
        "jsCode": "\nconst detected   = $('Detect Request Type').item.json;\nconst change     = detected.template_change || {};\nconst tplRows    = $input.all().map(i => i.json).filter(r => r && r.id);\nconst tpl        = tplRows[0] || null;\nconst now        = new Date().toISOString();\n\nconst event = String(change.event || '').toUpperCase();\n\n// Map Meta events to our status values\nconst statusMap = {\n  APPROVED:   'approved',\n  REJECTED:   'rejected',\n  DISABLED:   'rejected',\n  PAUSED:     'paused',\n  FLAGGED:    'flagged',\n  PENDING:    'pending',\n  IN_APPEAL:  'in_appeal',\n  REINSTATED: 'approved'\n};\nconst newStatus = statusMap[event] || 'pending';\n\n// Build notification data\nconst isApproved = newStatus === 'approved';\nconst isRejected = ['rejected', 'paused', 'flagged'].includes(newStatus);\n\nlet notifEventKey = null;\nlet notifTitle    = null;\nlet notifMessage  = null;\nif (isApproved) {\n  notifEventKey = 'template_approved';\n  notifTitle    = 'WhatsApp template approved';\n  notifMessage  = `Template \"${change.template_name}\" has been approved by Meta and is ready to use.`;\n} else if (isRejected) {\n  notifEventKey = 'template_rejected';\n  notifTitle    = 'WhatsApp template rejected';\n  notifMessage  = `Template \"${change.template_name}\" was rejected by Meta.` + (change.reason ? ` Reason: ${change.reason}` : '');\n}\n\nreturn [{ json: {\n  template_db_id:      tpl?.id          || null,\n  org_id:              tpl?.org_id      || null,\n  template_name:       change.template_name     || tpl?.name     || null,\n  template_language:   change.template_language || tpl?.language || null,\n  meta_template_id:    change.meta_template_id  || null,\n  new_status:          newStatus,\n  is_approved:         isApproved,\n  is_terminal:         isApproved || isRejected,\n  should_notify:       isApproved || isRejected,\n  rejection_reason:    change.reason || null,\n  notif_event_key:     notifEventKey,\n  notif_title:         notifTitle,\n  notif_message:       notifMessage,\n  notif_payload: {\n    template_name:     change.template_name,\n    template_language: change.template_language,\n    status:            newStatus,\n    meta_template_id:  change.meta_template_id,\n    entity:            'whatsapp_template'\n  },\n  now_iso: now\n}}];\n"
      },
