    {
      "parameters": {
        "jsCode": "\n// For GET verification requests, Meta sends query params: hub.mode, hub.verify_token, hub.challenge\n// For POST events, Meta sends JSON body with entry array\nconst q = $query || {};\nconst hubMode      = q['hub.mode']         || q.hub_mode        || '';\nconst hubChallenge = q['hub.challenge']    || q.hub_challenge   || '';\nconst hubVerify    = q['hub.verify_token'] || q.hub_verify_token || '';\n\nif (hubMode === 'subscribe' || hubChallenge) {\n  return [{ json: {\n    is_verification: true,\n    hub_challenge:    hubChallenge,\n    hub_verify_token: hubVerify\n  }}];\n}\n\n// POST event \u00e2\u20ac\u201d parse Meta webhook payload\nconst body = $json || {};\nconst entries = Array.isArray(body.entry) ? body.entry : [];\n\nlet change = null;\nlet eventWabaId = null;\n\nfor (const entry of entries) {\n  eventWabaId = entry.id || null;\n  for (const ch of (entry.changes || [])) {\n    if (ch.field === 'message_template_status_update') {\n      const v = ch.value || {};\n      change = {\n        event:              String(v.event || '').toUpperCase(),\n        meta_template_id:   v.message_template_id ? String(v.message_template_id) : null,\n        template_name:      v.message_template_name      || null,\n        template_language:  v.message_template_language  || null,\n        reason:             v.reason                     || null,\n        waba_id:            eventWabaId\n      };\n      break;\n    }\n  }\n  if (change) break;\n}\n\nreturn [{ json: {\n  is_verification:     false,\n  has_template_change: change !== null,\n  template_change:     change\n}}];\n"
      },
