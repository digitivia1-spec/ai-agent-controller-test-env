    {
      "parameters": {
        "jsCode": "\nconst ctx = $('Build Submission Context').item.json;\nconst raw = $input.all()[0]?.json || {};\nconst statusCode = raw.statusCode ?? 200;\nconst body = raw.body ?? raw;\n\n// Meta success response contains { id, status, category, name, language, ... }\nconst metaId     = body.id ? String(body.id) : null;\nconst metaStatus = body.status ? String(body.status).toLowerCase() : null;\nconst success    = statusCode >= 200 && statusCode < 300 && !!metaId && !body.error;\n\nlet errMsg = null;\nif (!success) {\n  if (body.error) {\n    errMsg = body.error.error_user_msg || body.error.message || JSON.stringify(body.error);\n  } else {\n    errMsg = `HTTP_${statusCode}: template creation failed`;\n  }\n}\n\nreturn [{ json: {\n  ...ctx,\n  meta_success: success,\n  meta_template_id: metaId,\n  meta_status: metaStatus || (success ? 'pending' : null),\n  meta_response: body,\n  meta_error: errMsg\n}}];\n"
      },
